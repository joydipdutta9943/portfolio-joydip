---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Architecting high-performance, polyglot microservices and enterprise-grade SaaS platforms.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = "Joydip Dutta — Software Engineer";
const ogTitle = title === siteTitle ? title : `${title} | Joydip Dutta`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Joydip Dutta" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Additional SEO -->
    <meta name="author" content="Joydip Dutta" />
    <meta name="robots" content="index, follow" />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Joydip Dutta",
        url: "https://sannin-coder.info",
        jobTitle: "Software Engineer",
        sameAs: [
          "https://github.com/joydipdutta9943",
          "https://www.linkedin.com/in/joydip-dutta-569428141/",
        ],
      })}
    />

    <ClientRouter />
  </head>
  <body class="bg-dot-pattern">
    <div
      class="via-background/80 to-background pointer-events-none fixed inset-0 min-h-screen flex-shrink-0 bg-gradient-to-b from-transparent"
    >
    </div>
    <div class="relative z-10 mx-auto w-full max-w-4xl px-6 py-12 lg:py-24">
      <header
        class="mb-20 flex flex-col items-baseline justify-between gap-4 border-b border-zinc-800/50 pb-6 md:flex-row"
      >
        <a
          href="/"
          class="text-foreground hover:text-accent font-mono font-sans text-xl font-bold tracking-tight transition-colors"
        >
          jd.init()<span class="text-accent animate-pulse">_</span>
        </a>
        <nav class="flex gap-6 font-mono text-sm">
          <a href="/" class="hover:text-accent focus-visible:text-accent transition-colors">~ /</a>
          <a
            href="/experience"
            class="hover:text-accent focus-visible:text-accent transition-colors">~ /experience</a
          >
          <a href="/projects" class="hover:text-accent focus-visible:text-accent transition-colors"
            >~ /projects</a
          >
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer
        class="mt-32 flex flex-col items-center justify-between gap-6 border-t border-zinc-800 pt-8 font-mono text-xs text-zinc-500 md:flex-row md:gap-4"
      >
        <div class="flex flex-col items-center gap-4 md:flex-row md:gap-6">
          <span>© {new Date().getFullYear()} Joydip Dutta. All rights reserved.</span>
          <div class="flex gap-4">
            <a
              href="https://github.com/joydipdutta9943"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-zinc-300">GitHub</a
            >
            <a
              href="https://www.linkedin.com/in/joydip-dutta-569428141/"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-zinc-300">LinkedIn</a
            >
            <a
              href="mailto:joydip.dutta9943@gmail.com"
              class="transition-colors hover:text-zinc-300">Email</a
            >
          </div>
        </div>
        <span class="flex items-center gap-2">
          <span class="bg-accent h-2 w-2 animate-pulse rounded-full"></span>
          System.Status: ONLINE
        </span>
      </footer>
    </div>
  </body>
</html>
