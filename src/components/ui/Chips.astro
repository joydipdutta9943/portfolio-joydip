---
interface Props {
  items: string[];
  max?: number;
  class?: string;
  chipClass?: string;
}
const { items, max, class: className = "", chipClass = "" } = Astro.props;
const shown = typeof max === "number" ? items.slice(0, max) : items;
const overflow = typeof max === "number" && items.length > max ? items.length - max : 0;
---

<div class:list={["pk-chips", className]}>
  {shown.map((item) => <span class:list={["pk-chip", chipClass]}>{item}</span>)}
  {
    overflow > 0 && (
      <span class:list={["pk-chip", chipClass]} style="opacity:.7">
        +{overflow} more
      </span>
    )
  }
</div>
