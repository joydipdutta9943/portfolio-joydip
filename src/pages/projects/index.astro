---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const featured = sortedProjects.filter((p) => p.data.image);
const rest = sortedProjects.filter((p) => !p.data.image);
---

<Layout
  title="Projects | Joydip Dutta — Freelance Product Engineer"
  description="Case studies and projects — fintech backends, AI agents, microservices, and full-stack applications."
>
  <div class="mx-auto max-w-7xl px-6 pb-24">

    <!-- Header -->
    <div class="mb-16 pt-4">
      <a
        href="/"
        class="group mb-8 inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-foreground"
      >
        <svg
          class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Home
      </a>

      <h1 class="font-display mb-4 text-4xl font-semibold tracking-[-0.03em] text-foreground md:text-5xl">
        All projects
      </h1>
      <p class="max-w-xl text-base text-muted">
        Case studies from production systems — fintech, AI, microservices, and full-stack SaaS builds.
      </p>
    </div>

    <!-- Featured projects with images -->
    {featured.length > 0 && (
      <section class="mb-16">
        <div class="mb-6 border-b border-border pb-3">
          <span class="font-mono text-[11px] uppercase tracking-widest text-subtle">Featured</span>
        </div>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {featured.map((project, i) => (
            <a
              href={`/projects/${project.id}`}
              class:list={[
                "card-surface group relative flex flex-col overflow-hidden rounded-xl transition-all duration-300 hover:border-border-strong",
                i === 0 && "md:col-span-2",
              ]}
            >
              <div
                class:list={[
                  "relative w-full shrink-0 overflow-hidden border-b border-border bg-surface-raised",
                  i === 0 ? "h-56 md:h-72" : "h-44 md:h-52",
                ]}
              >
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="h-full w-full object-cover opacity-80 transition-all duration-500 group-hover:scale-[1.03] group-hover:opacity-100"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-background/60 to-transparent"></div>
              </div>

              <div class="flex flex-1 flex-col p-6">
                <div class="mb-2 flex items-start justify-between gap-4">
                  <h2 class="font-display text-lg font-semibold text-foreground">{project.data.title}</h2>
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-muted opacity-0 transition-all duration-300 group-hover:translate-x-0.5 group-hover:opacity-100"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </div>

                <p class="mb-5 flex-1 text-sm leading-relaxed text-muted">{project.data.description}</p>

                <div class="mt-auto flex flex-wrap gap-1.5">
                  {project.data.techStack.slice(0, 4).map((tech) => (
                    <span class="rounded-md border border-border bg-white/[0.02] px-2 py-1 font-mono text-[11px] text-muted">
                      {tech}
                    </span>
                  ))}
                  {project.data.techStack.length > 4 && (
                    <span class="rounded-md border border-border bg-white/[0.02] px-2 py-1 font-mono text-[11px] text-subtle">
                      +{project.data.techStack.length - 4} more
                    </span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Other projects -->
    {rest.length > 0 && (
      <section>
        <div class="mb-6 border-b border-border pb-3">
          <span class="font-mono text-[11px] uppercase tracking-widest text-subtle">More projects</span>
        </div>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {rest.map((project) => (
            <a
              href={`/projects/${project.id}`}
              class="card-surface group flex flex-col rounded-xl p-6 transition-all duration-300 hover:border-border-strong"
            >
              <h2 class="font-display mb-2 text-base font-semibold text-foreground">{project.data.title}</h2>

              <p class="mb-5 flex-1 text-sm leading-relaxed text-muted">{project.data.description}</p>

              <div class="mt-auto flex flex-wrap gap-1.5">
                {project.data.techStack.slice(0, 3).map((tech) => (
                  <span class="rounded-md border border-border bg-white/[0.02] px-2 py-0.5 font-mono text-[11px] text-muted">
                    {tech}
                  </span>
                ))}
                {project.data.techStack.length > 3 && (
                  <span class="rounded-md border border-border bg-white/[0.02] px-2 py-0.5 font-mono text-[11px] text-subtle">
                    +{project.data.techStack.length - 3}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>
