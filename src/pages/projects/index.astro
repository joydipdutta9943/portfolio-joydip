---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const featured = sortedProjects.filter((p) => p.data.image);
const rest = sortedProjects.filter((p) => !p.data.image);
---

<Layout
  title="Projects & Case Studies | Joydip Dutta — Software Development Engineer"
  description="Explore Joydip Dutta's engineering projects — fintech backends, AI agents, microservices, and full-stack applications with detailed case studies."
>
  <div class="mx-auto max-w-5xl px-6 pb-24">
  <section class="animate-in fade-in slide-in-from-bottom-4 mb-16 max-w-2xl duration-700 ease-out">
    <h1 class="text-foreground mb-4 text-4xl font-black tracking-tighter md:text-5xl">
      Project_Log
    </h1>
    <p class="text-muted inline-block rounded-lg border border-zinc-800 bg-zinc-950 p-4 font-mono">
      <span class="text-accent">~ $ ls -la /var/log/case-studies</span>
    </p>
  </section>

  <!-- Featured projects with images -->
  <section class="mb-12">
    <h3
      class="mb-6 flex items-center border-b border-zinc-800 pb-3 font-mono text-sm tracking-widest text-zinc-500 uppercase"
    >
      <span class="text-accent mr-3">>&nbsp;</span>Featured
    </h3>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {
        featured.map((project, i) => (
          <a
            href={`/projects/${project.id}`}
            class:list={[
              "group relative flex flex-col overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950 transition-all hover:border-zinc-600 hover:bg-zinc-900",
              i === 0 && "md:col-span-2",
            ]}
          >
            <div
              class:list={[
                "relative w-full shrink-0 overflow-hidden border-b border-zinc-800 bg-zinc-900",
                i === 0 ? "h-56 md:h-64" : "h-40 md:h-48",
              ]}
            >
              <div class="absolute inset-0 z-10 bg-zinc-950/20 transition-colors duration-500 group-hover:bg-transparent" />
              <img
                src={project.data.image}
                alt={project.data.title}
                class="h-full w-full object-cover opacity-80 transition-all duration-700 ease-out group-hover:scale-105 group-hover:opacity-100"
              />
            </div>

            <div class="flex flex-1 flex-col p-5 md:p-6">
              <h2 class="text-foreground mb-3 flex items-center justify-between text-xl font-bold">
                {project.data.title}
                <span class="text-accent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </>
                  </svg>
                </span>
              </h2>

              <p class="text-muted mb-5 flex-1 font-mono text-sm leading-relaxed">
                {project.data.description}
              </p>

              <div class="mt-auto flex flex-wrap gap-2">
                {project.data.techStack.slice(0, 4).map((tech) => (
                  <span class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400 transition-colors group-hover:border-zinc-700">
                    {tech}
                  </span>
                ))}
                {project.data.techStack.length > 4 && (
                  <span class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-500">
                    +{project.data.techStack.length - 4}
                  </span>
                )}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Other projects in compact grid -->
  <section class="pb-24">
    <h3
      class="mb-6 flex items-center border-b border-zinc-800 pb-3 font-mono text-sm tracking-widest text-zinc-500 uppercase"
    >
      <span class="text-accent mr-3">>&nbsp;</span>More Projects
    </h3>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        rest.map((project) => (
          <a
            href={`/projects/${project.id}`}
            class="group relative flex flex-col rounded-lg border border-zinc-800 bg-zinc-950 p-5 transition-all hover:border-zinc-600 hover:bg-zinc-900"
          >
            <div class="group-hover:bg-accent absolute inset-y-0 left-0 z-20 w-0.5 rounded-l-lg bg-transparent transition-colors" />

            <h2 class="text-foreground mb-2 text-base leading-snug font-bold">
              {project.data.title}
            </h2>

            <p class="text-muted mb-4 flex-1 font-mono text-xs leading-relaxed">
              {project.data.description}
            </p>

            <div class="mt-auto flex flex-wrap gap-1.5">
              {project.data.techStack.slice(0, 3).map((tech) => (
                <span class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-0.5 font-mono text-xs text-zinc-500 transition-colors group-hover:border-zinc-700 group-hover:text-zinc-400">
                  {tech}
                </span>
              ))}
              {project.data.techStack.length > 3 && (
                <span class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-0.5 font-mono text-xs text-zinc-600">
                  +{project.data.techStack.length - 3}
                </span>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </section>
  </div>
</Layout>
