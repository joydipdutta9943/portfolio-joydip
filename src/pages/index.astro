---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Joydip Dutta — Software Development Engineer | Backend, Microservices & AI"
  description="Joydip Dutta is a Software Development Engineer specializing in high-performance microservices, enterprise SaaS platforms, and AI systems using TypeScript, Go, and Python."
>
  <section class="animate-in fade-in slide-in-from-bottom-4 mb-24 max-w-2xl duration-700 ease-out">
    <div class="mb-6 flex items-center gap-3">
      <span class="relative flex h-3 w-3">
        <span
          class="bg-accent absolute inline-flex h-full w-full animate-ping rounded-full opacity-75"
        ></span>
        <span class="bg-accent relative inline-flex h-3 w-3 rounded-full"></span>
      </span>
      <span
        class="text-accent border-accent/20 bg-accent/5 rounded-full border px-2 py-0.5 font-mono text-sm font-semibold tracking-wider"
        >Open to Work</span
      >
    </div>

    <h1
      class="text-foreground mb-6 text-4xl leading-[1.1] font-black tracking-tighter md:text-5xl lg:text-7xl"
    >
      Joydip Dutta <br />
      <span class="mt-2 block text-2xl font-bold tracking-tight text-zinc-500 md:text-3xl"
        >Software Development Engineer</span
      >
    </h1>

    <h2 class="mb-8 text-xl leading-snug font-medium text-zinc-300 md:text-2xl">
      Architecting high-performance, polyglot microservices, enterprise SaaS platforms, and
      intelligent AI systems.
    </h2>

    <div class="mb-10 flex flex-wrap items-center gap-3 font-mono text-sm md:gap-4">
      <a
        href="https://github.com/joydipdutta9943"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-2 rounded-md border border-zinc-800 bg-zinc-900/50 px-4 py-2.5 text-zinc-300 transition-all hover:border-zinc-500 hover:bg-zinc-800 hover:text-white hover:shadow-md focus-visible:border-zinc-500 focus-visible:bg-zinc-800 focus-visible:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:scale-110"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        >
        <span class="font-medium">GitHub</span>
      </a>
      <a
        href="https://www.linkedin.com/in/joydip-dutta-569428141/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-2 rounded-md border border-zinc-800 bg-zinc-900/50 px-4 py-2.5 text-zinc-300 transition-all hover:border-[#0a66c2]/50 hover:bg-zinc-800 hover:text-[#0a66c2] hover:shadow-md focus-visible:border-[#0a66c2]/50 focus-visible:bg-zinc-800 focus-visible:text-[#0a66c2]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:scale-110"
          ><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"
          ></circle></svg
        >
        <span class="font-medium">LinkedIn</span>
      </a>
      <a
        href="mailto:joydip.dutta9943@gmail.com"
        class="group hover:border-accent/50 hover:text-accent focus-visible:border-accent/50 focus-visible:text-accent flex items-center gap-2 rounded-md border border-zinc-800 bg-zinc-900/50 px-4 py-2.5 text-zinc-300 transition-all hover:bg-zinc-800 hover:shadow-md focus-visible:bg-zinc-800"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:scale-110"
          ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
        <span class="font-medium">joydip.dutta9943@gmail.com</span>
      </a>
    </div>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
      <div
        class="group relative overflow-hidden rounded-lg border border-zinc-800/80 bg-zinc-950 p-5 transition-all hover:border-zinc-700"
      >
        <div
          class="from-accent/5 absolute inset-0 bg-gradient-to-br to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        >
        </div>
        <div class="relative z-10">
          <span class="text-accent mb-1 block font-mono text-2xl font-black md:text-3xl">3+</span>
          <span class="font-mono text-xs tracking-wide text-zinc-500 uppercase">Years Exp</span>
        </div>
      </div>
      <div
        class="group relative overflow-hidden rounded-lg border border-zinc-800/80 bg-zinc-950 p-5 transition-all hover:border-zinc-700"
      >
        <div
          class="from-accent/5 absolute inset-0 bg-gradient-to-br to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        >
        </div>
        <div class="relative z-10">
          <span class="text-accent mb-1 block font-mono text-2xl font-black md:text-3xl">30k+</span>
          <span class="font-mono text-xs tracking-wide text-zinc-500 uppercase">Users Served</span>
        </div>
      </div>
      <div
        class="group relative overflow-hidden rounded-lg border border-zinc-800/80 bg-zinc-950 p-5 transition-all hover:border-zinc-700"
      >
        <div
          class="from-accent/5 absolute inset-0 bg-gradient-to-br to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        >
        </div>
        <div class="relative z-10">
          <span class="text-accent mb-1 block font-mono text-2xl font-black md:text-3xl">99.9%</span
          >
          <span class="font-mono text-xs tracking-wide text-zinc-500 uppercase">Uptime SLA</span>
        </div>
      </div>
      <div
        class="group relative overflow-hidden rounded-lg border border-zinc-800/80 bg-zinc-950 p-5 transition-all hover:border-zinc-700"
      >
        <div
          class="from-accent/5 absolute inset-0 bg-gradient-to-br to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        >
        </div>
        <div class="relative z-10">
          <span class="text-accent mb-1 block font-mono text-2xl font-black md:text-3xl">12+</span>
          <span class="font-mono text-xs tracking-wide text-zinc-500 uppercase">Projects</span>
        </div>
      </div>
    </div>
  </section>

  <div class="mb-16 flex items-center gap-4">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
  </div>

  <section class="mb-32">
    <h3
      class="mb-8 flex items-center border-b border-zinc-800 pb-4 font-mono text-sm tracking-widest text-zinc-500 uppercase"
    >
      <span class="text-accent mr-3">>&nbsp;</span>[01] // Technical_Arsenal
    </h3>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div
        class="group rounded-lg border border-zinc-800/80 bg-zinc-950 p-6 transition-colors hover:border-sky-500/40"
      >
        <h4 class="mb-4 flex items-center gap-3 font-mono text-sm font-bold uppercase">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-md bg-sky-500/10 text-sky-400"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"
              ></polyline></svg
            >
          </span>
          <span class="text-foreground">Languages & Frameworks</span>
        </h4>
        <div class="flex flex-wrap gap-2">
          {
            [
              "TypeScript",
              "Go (Fiber)",
              "Bun",
              "Python",
              "Node.js",
              "GraphQL",
              "React",
              "Next.js",
              "Astro",
            ].map((tech) => (
              <span class="cursor-default rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400 transition-colors hover:border-sky-500/50 hover:text-sky-400">
                {tech}
              </span>
            ))
          }
        </div>
      </div>

      <div
        class="group rounded-lg border border-zinc-800/80 bg-zinc-950 p-6 transition-colors hover:border-amber-500/40"
      >
        <h4 class="mb-4 flex items-center gap-3 font-mono text-sm font-bold uppercase">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-md bg-amber-500/10 text-amber-400"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"
              ></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg
            >
          </span>
          <span class="text-foreground">Databases & Storage</span>
        </h4>
        <div class="flex flex-wrap gap-2">
          {
            [
              "PostgreSQL",
              "MongoDB",
              "ClickHouse",
              "Redis",
              "DynamoDB",
              "Prisma",
              "Drizzle",
              "AWS S3",
            ].map((tech) => (
              <span class="cursor-default rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400 transition-colors hover:border-amber-500/50 hover:text-amber-400">
                {tech}
              </span>
            ))
          }
        </div>
      </div>

      <div
        class="group rounded-lg border border-zinc-800/80 bg-zinc-950 p-6 transition-colors hover:border-rose-500/40"
      >
        <h4 class="mb-4 flex items-center gap-3 font-mono text-sm font-bold uppercase">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-md bg-rose-500/10 text-rose-400"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path></svg
            >
          </span>
          <span class="text-foreground">Infrastructure & Security</span>
        </h4>
        <div class="flex flex-wrap gap-2">
          {
            [
              "Docker",
              "Kubernetes",
              "BullMQ",
              "AWS (SQS, SES)",
              "AES-256-GCM",
              "HMAC",
              "Ngrok",
            ].map((tech) => (
              <span class="cursor-default rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400 transition-colors hover:border-rose-500/50 hover:text-rose-400">
                {tech}
              </span>
            ))
          }
        </div>
      </div>

      <div
        class="group rounded-lg border border-zinc-800/80 bg-zinc-950 p-6 transition-colors hover:border-violet-500/40"
      >
        <h4 class="mb-4 flex items-center gap-3 font-mono text-sm font-bold uppercase">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-md bg-violet-500/10 text-violet-400"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M12 2a4 4 0 0 0-4 4c0 2 2 3 2 6H8a2 2 0 1 0 0 4h8a2 2 0 1 0 0-4h-2c0-3 2-4 2-6a4 4 0 0 0-4-4Z"
              ></path><line x1="12" y1="18" x2="12" y2="22"></line></svg
            >
          </span>
          <span class="text-foreground">AI & Search</span>
        </h4>
        <div class="flex flex-wrap gap-2">
          {
            [
              "LangChain",
              "Google Gemini",
              "OpenAI",
              "Vector Search (pgvector, Atlas)",
              "RAG Architecture",
            ].map((tech) => (
              <span class="cursor-default rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400 transition-colors hover:border-violet-500/50 hover:text-violet-400">
                {tech}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <div class="mb-16 flex items-center gap-4">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
  </div>

  <section class="mb-16">
    <h3
      class="mb-8 flex items-center border-b border-zinc-800 pb-4 font-mono text-sm tracking-widest text-zinc-500 uppercase"
    >
      <span class="text-accent mr-3">>&nbsp;</span>[02] // Featured_Operations
    </h3>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <a
        href="/projects/unified-ai-agent"
        class="group relative block overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950 transition-all hover:border-zinc-600 hover:bg-zinc-900"
      >
        <div
          class="relative h-40 w-full overflow-hidden border-b border-zinc-800 bg-zinc-900 md:h-44"
        >
          <div
            class="absolute inset-0 z-10 bg-zinc-950/30 transition-colors duration-500 group-hover:bg-transparent"
          >
          </div>
          <img
            src="/images/unified-ai-agent.png"
            alt="Unified AI Agent"
            class="h-full w-full object-cover opacity-80 transition-all duration-700 ease-out group-hover:scale-105 group-hover:opacity-100"
          />
        </div>
        <div class="p-6">
          <h4 class="text-foreground mb-3 flex items-center justify-between text-lg font-bold">
            Unified Multi-Modal AI Agent
            <span class="group-hover:text-accent font-mono text-xs text-zinc-400 transition-colors"
              >[Case Study]</span
            >
          </h4>
          <p class="text-muted mb-5 font-mono text-sm leading-relaxed">
            Production-ready RAG system for complex natural language queries on unstructured data.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="text-accent bg-accent/10 border-accent/20 rounded-sm border px-2 py-1 font-mono text-xs"
              >LangChain</span
            >
            <span
              class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400"
              >Gemini</span
            >
            <span
              class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400"
              >Vector Search</span
            >
          </div>
        </div>
      </a>

      <a
        href="/projects/gunpowder-fintech-backend"
        class="group relative block overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950 transition-all hover:border-zinc-600 hover:bg-zinc-900"
      >
        <div
          class="relative h-40 w-full overflow-hidden border-b border-zinc-800 bg-zinc-900 md:h-44"
        >
          <div
            class="absolute inset-0 z-10 bg-zinc-950/30 transition-colors duration-500 group-hover:bg-transparent"
          >
          </div>
          <img
            src="/images/gunpowder-fintech-backend.png"
            alt="Gunpowder Fintech Backend"
            class="h-full w-full object-cover opacity-80 transition-all duration-700 ease-out group-hover:scale-105 group-hover:opacity-100"
          />
        </div>
        <div class="p-6">
          <h4 class="text-foreground mb-3 flex items-center justify-between text-lg font-bold">
            Gunpowder Fintech Backend
            <span class="group-hover:text-accent font-mono text-xs text-zinc-400 transition-colors"
              >[Case Study]</span
            >
          </h4>
          <p class="text-muted mb-5 font-mono text-sm leading-relaxed">
            Enterprise wealth management platform with investment accounts, KYC, and direct debits.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="text-accent bg-accent/10 border-accent/20 rounded-sm border px-2 py-1 font-mono text-xs"
              >TypeScript</span
            >
            <span
              class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400"
              >Prisma</span
            >
            <span
              class="rounded-sm border border-zinc-800 bg-zinc-900 px-2 py-1 font-mono text-xs text-zinc-400"
              >BullMQ</span
            >
          </div>
        </div>
      </a>

      <div class="mt-6 flex justify-end">
        <a
          href="/projects"
          class="hover:text-foreground group inline-flex items-center font-mono text-sm text-zinc-400 transition-colors"
        >
          Execute /projects/list.sh
          <svg
            class="group-hover:text-accent ml-2 transition-transform group-hover:translate-x-1"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>
  </section>
</Layout>
